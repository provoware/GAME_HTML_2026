{
  "name": "game-html-2026",
  "version": "0.0.0",
  "private": true,
  "description": "Statisch deploybares Retro-Browsergame PPPoppi 1986 — Euronen, Ehre, Untergrund.",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit --strict --lib DOM,DOM.Iterable,ES2022 --module ESNext --moduleResolution Bundler --target ES2022 src/main.ts src/vite-env.d.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "browsergame",
    "retro",
    "typescript",
    "vite"
  ],
  "author": "provoware",
  "license": "UNLICENSED",
  "devDependencies": {
    "@playwright/test": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
